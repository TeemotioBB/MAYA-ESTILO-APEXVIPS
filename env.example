# ═══════════════════════════════════════════════════════════════════════════════
# 🤖 TELEGRAM
# ═══════════════════════════════════════════════════════════════════════════════
# Pegue com o @BotFather no Telegram
BOT_TOKEN=

# Nome da persona (Maya, Sophia, Bia, etc) — aparece nas mensagens
BOT_PERSONA_NAME=Maya

# ═══════════════════════════════════════════════════════════════════════════════
# 💳 SYNCPAY
# ═══════════════════════════════════════════════════════════════════════════════
# Painel SyncPay → API → Credenciais
SYNCPAY_CLIENT_ID=
SYNCPAY_CLIENT_SECRET=
SYNCPAY_BASE_URL=https://api.syncpayments.com.br/api/partner/v1

# ═══════════════════════════════════════════════════════════════════════════════
# 🌐 WEBHOOK
# ═══════════════════════════════════════════════════════════════════════════════
# URL pública onde o Flask escuta (SyncPay vai bater aqui).
# Em DEV use ngrok ou cloudflared. Em PROD aponte seu domínio (com HTTPS).
# Sem barra no final.
WEBHOOK_BASE_URL=https://seudominio.com
FLASK_PORT=8080

# ═══════════════════════════════════════════════════════════════════════════════
# 🗄️ REDIS
# ═══════════════════════════════════════════════════════════════════════════════
REDIS_URL=redis://localhost:6379/0

# ═══════════════════════════════════════════════════════════════════════════════
# 🎁 ENTREGÁVEIS
# ═══════════════════════════════════════════════════════════════════════════════
# ID dos canais privados (formato -100xxxxxxxxxx).
# O bot PRECISA ser admin desses canais com permissão "Convidar Usuários".
VIP_CHANNEL_ID=
VIP_PLUS_CHANNEL_ID=

# Link de convite de backup (caso a geração automática falhe).
VIP_CHANNEL_FALLBACK=

# WhatsApp pessoal (entregue no plano "MEU WHATSAPP PESSOAL" e no upsell)
WHATSAPP_CONTACT=https://wa.me/5511999999999
